{
  "name": "@sf-voice/sohoist",
  "private": true,
  "main": "apps/native/index.tsx",
  "scripts": {
    "predev": "sh scripts/sync-env.sh",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "testflight": "pnpm --filter native-app testflight",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "turbo": "2.9.6"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.33.0"
}

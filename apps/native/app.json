{
  "expo": {
    "newArchEnabled": true,
    "name": "Sohoist",
    "slug": "sohoist",
    "scheme": "sohoist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sohoist.app",
      "buildNumber": "1",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sohoist needs your microphone to create your voice profile.",
        "NSPhotoLibraryUsageDescription": "Sohoist uses your photos to generate a private pencil sketch portrait."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE6"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

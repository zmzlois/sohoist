apps/native/ios/build/
apps/native/ios/Pods/
apps/native/android/build/
apps/native/android/.gradle/
apps/native/android/app/build/

# ios xcode env — contains local machine paths, not portable
apps/native/ios/.xcode.env.local

# ── logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

